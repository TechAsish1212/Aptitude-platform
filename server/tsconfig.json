{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    // File Layout
    "rootDir": "./src",
    "outDir": "./dist",

    // Environment Settings
    // See also https://aka.ms/tsconfig/module
    "module": "commonjs",
    "target": "es6",
    "types": ["node"],  // ✅ Add node types
    "lib": ["esnext"],  // ✅ Add lib for nodejs
    
    // Other Outputs
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    // Stricter Typechecking Options (relaxed a bit for commonjs)
    "noUncheckedIndexedAccess": false,  // ✅ Set to false
    "exactOptionalPropertyTypes": false,  // ✅ Set to false

    // Recommended Options
    "strict": false,  // ✅ Set to false initially for commonjs
    "jsx": "react-jsx",
    "verbatimModuleSyntax": false,  // ✅ CHANGE THIS to false
    "isolatedModules": false,  // ✅ Set to false
    "noUncheckedSideEffectImports": false,  // ✅ Set to false
    "moduleDetection": "auto",  // ✅ CHANGE THIS to "auto"
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,  // ✅ Add this
    
    // Additional helpful options
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}